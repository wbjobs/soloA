{
  "name": "shared-terminal",
  "version": "1.0.0",
  "description": "Multi-user real-time shared terminal system",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server": "npm --workspace=server run dev",
    "client": "npm --workspace=client run dev",
    "build": "npm --workspace=server run build && npm --workspace=client run build"
  }
}